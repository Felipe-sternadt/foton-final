NODE_ENV=development
PORT=3000

# Origens extras permitidas. Requisicoes no mesmo dominio sao aceitas automaticamente.
CORS_ORIGINS=http://localhost:3000,https://seudominio.com.br

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=foton_user
DB_PASSWORD=troque_esta_senha
DB_NAME=foton_leads
# Ative quando o MySQL estiver em outro servidor e oferecer conexao TLS.
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# CRM opcional
CRM_ENABLED=false
CRM_ENDPOINT=
CRM_TOKEN=

# Resend. A chave real existe somente no .env local ou no hPanel da Hostinger.
RESEND_ENABLED=false
RESEND_API_KEY=
RESEND_FROM=Leads Someval Foton <leads@somevalfoton.com.br>

# Destinatarios fixos por unidade
RESEND_RECIPIENT_PALHOCA=gerencia.vendas1@somevalfoton.com.br
RESEND_RECIPIENT_JOINVILLE=gerencia.vendas2@somevalfoton.com.br
RESEND_RECIPIENT_BLUMENAU=gerencia.vendas3@somevalfoton.com.br
